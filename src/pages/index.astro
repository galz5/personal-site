<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gal Oz</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #050505;
      --text: #e8e6e3;
      --accent: #6d9aff;
      --accent-dim: rgba(109, 154, 255, 0.08);
      --grain-opacity: 0.03;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Space Mono', monospace;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }

    /* Grain overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      opacity: var(--grain-opacity);
      pointer-events: none;
      z-index: 10;
    }

    /* Subtle grid background */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(109, 154, 255, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(109, 154, 255, 0.03) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
    }

    /* Glow orb */
    .glow {
      position: fixed;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(109, 154, 255, 0.08) 0%, transparent 70%);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: pulse 6s ease-in-out infinite;
      pointer-events: none;
    }

    @keyframes pulse {
      0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
      50% { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
    }

    .container {
      text-align: center;
      position: relative;
      z-index: 5;
      padding: 2rem;
    }

    .domain {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.5rem, 8vw, 5rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.25rem;
      animation: fadeUp 1s ease-out both;
    }

    .domain .tld {
      color: var(--accent);
    }

    .status {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8rem;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-bottom: 2.5rem;
      animation: fadeUp 1s ease-out 0.2s both;
    }

    .status::before {
      content: '';
      width: 6px;
      height: 6px;
      background: var(--accent);
      border-radius: 50%;
      animation: blink 2s ease-in-out infinite;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    .message {
      font-size: 0.95rem;
      color: #7a7876;
      line-height: 1.7;
      max-width: 380px;
      margin: 0 auto 2.5rem;
      animation: fadeUp 1s ease-out 0.4s both;
    }

    .terminal {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(109, 154, 255, 0.1);
      border-radius: 8px;
      padding: 1.25rem 1.75rem;
      display: inline-block;
      text-align: left;
      font-size: 0.8rem;
      color: #5a5856;
      animation: fadeUp 1s ease-out 0.6s both;
    }

    .terminal .line {
      margin-bottom: 0.3rem;
    }

    .terminal .line:last-child {
      margin-bottom: 0;
    }

    .terminal .prompt {
      color: var(--accent);
    }

    .terminal .cmd {
      color: var(--text);
    }

    .terminal .comment {
      color: #3a3836;
    }

    .cursor-blink {
      display: inline-block;
      width: 8px;
      height: 14px;
      background: var(--accent);
      margin-left: 2px;
      vertical-align: text-bottom;
      animation: cursorBlink 1s step-end infinite;
    }

    @keyframes cursorBlink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    .contact {
      margin-top: 2.5rem;
      animation: fadeUp 1s ease-out 0.8s both;
    }

    .contact a {
      color: #5a5856;
      text-decoration: none;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      transition: color 0.3s;
    }

    .contact a:hover {
      color: var(--accent);
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</head>
<body>
  <div class="glow"></div>

  <div class="container">
    <h1 class="domain">galoz<span class="tld">.dev</span></h1>
    <div class="status">Under Construction</div>
    <p class="message">
      Something new is being built here.<br>
      Come back soon.
    </p>
    <div class="terminal">
      <div class="line"><span class="prompt">~</span> <span class="cmd">astro build</span></div>
      <div class="line"><span class="comment">// assembling pages...</span></div>
      <div class="line"><span class="prompt">~</span> <span class="cmd">deploy --global</span><span class="cursor-blink"></span></div>
    </div>
    <div class="contact">
      <a href="mailto:hey@galoz.dev">hey@galoz.dev</a>
    </div>
  </div>
</body>
</html>